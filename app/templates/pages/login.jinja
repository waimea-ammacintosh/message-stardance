=====================================================#}

{% extends 'pages/_base.jinja' %}


{% block content %}

    <h2>Login</h2>

    <form method="post" action="/login">

      <label>
        Username
        <input type="text" name="username" required>
      </label>

      <label>
        Password
        <input type="password" name="password" required>
      </label>

      <button>Log in</button>
    </form>

{% endblock %}

